<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Order</title>

    <link rel="stylesheet" href="stylesheet/styles.css">
</head>
<body>
    <h1>Thank You For Your Order!</h1>
    <h2>Your ice cream order has been confirmed.</h2>

    <h3>Personal Information</h3>
    <p>Name: <%= order.name %></p>
    <p>Email: <%= order.email %></p>

    <h3>Order Details</h3>
    <p>Flavor: <%= order.flavors.join(', ') %></p>
    <p>Cone: <%= order.cone %></p>
    <p>Toppings: <%= order.toppings.length ? order.toppings.join(', ') : 'None' %></p>

    <h3>Additional Comments</h3>
    <p><%= order.comment || 'No comments provided.' %></p>

    <a href="/print">Print Order</a>
    <a href="/">Place Another Order</a>
    <a href="/admin">View All Orders</a>
</body>
</html>